---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Disk visualizer and cleanup app for Apple Silicon Macs. Open source, MIT licensed.",
} = Astro.props;

const fullTitle = title === "Mac Storage Clear" ? title : `${title} · Mac Storage Clear`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-paper text-ink font-sans antialiased min-h-screen flex flex-col">
    <header class="border-b border-black/5">
      <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="font-semibold tracking-tight text-lg">Mac Storage Clear</a>
        <nav class="flex gap-6 text-sm text-ink/70">
          <a href="/#features" class="hover:text-ink">Features</a>
          <a href="/support" class="hover:text-ink">Support</a>
          <a
            href="https://github.com/aanya-send-help/mac-storage-clear"
            class="hover:text-ink"
            rel="noopener">GitHub</a
          >
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-black/5 mt-16">
      <div
        class="max-w-5xl mx-auto px-6 py-8 text-sm text-ink/60 flex flex-wrap gap-4 justify-between"
      >
        <div>© 2026 Ishan Sharma (Mirelle, d/b/a flek.ai). MIT licensed.</div>
        <div class="flex gap-4">
          <a href="/privacy" class="hover:text-ink">Privacy</a>
          <a href="/terms" class="hover:text-ink">Terms</a>
          <a href="/support" class="hover:text-ink">Support</a>
        </div>
      </div>
    </footer>
  </body>
</html>
