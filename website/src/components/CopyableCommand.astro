---
interface Props {
  command: string;
  label?: string;
}
const { command, label } = Astro.props;
---

<div class="copyable-command relative group" data-command={command}>
  {label && <p class="text-xs text-ink/60 mb-2">{label}</p>}
  <pre
    class="bg-ink text-paper rounded-lg px-4 py-3 pr-14 text-sm overflow-x-auto font-mono leading-relaxed"><code>{command}</code></pre>
  <button
    type="button"
    class="copy-btn absolute top-2.5 right-2.5 px-2.5 py-1 text-xs rounded bg-paper/10 hover:bg-paper/20 text-paper border border-paper/15 transition-colors"
    aria-label="Copy command to clipboard"
  >
    Copy
  </button>
</div>

<script>
  function attachCopyHandlers() {
    document.querySelectorAll<HTMLDivElement>(".copyable-command").forEach((el) => {
      const btn = el.querySelector<HTMLButtonElement>(".copy-btn");
      if (!btn || btn.dataset.bound === "true") return;
      btn.dataset.bound = "true";
      btn.addEventListener("click", async () => {
        const cmd = el.dataset.command ?? "";
        try {
          await navigator.clipboard.writeText(cmd);
          const original = btn.textContent;
          btn.textContent = "Copied";
          btn.classList.add("text-green-300");
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove("text-green-300");
          }, 1400);
        } catch {
          btn.textContent = "Copy failed";
          setTimeout(() => {
            btn.textContent = "Copy";
          }, 1400);
        }
      });
    });
  }
  attachCopyHandlers();
  document.addEventListener("astro:page-load", attachCopyHandlers);
</script>
