<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store build. App Sandbox is mandatory. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- User-selected folders via NSOpenPanel; persisted as security-scoped bookmarks. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>

    <!-- Read access to the user's home (paired with Full Disk Access at runtime). -->
    <key>com.apple.security.files.home-relative-path.read-write</key>
    <array>
        <string>/</string>
    </array>

    <!-- WKWebView in sandbox. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
